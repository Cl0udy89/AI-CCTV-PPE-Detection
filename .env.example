# ── SafeVision PPE — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values before deploying.
#
#   cp .env.example .env
#   nano .env

# JWT signing secret — change this to a long random string in production!
# Generate one with: openssl rand -hex 32
PPE_SECRET_KEY=change-this-to-a-random-secret-in-production

# Port the frontend/Nginx container listens on (default: 80)
# Change to 8080 or 443 if port 80 is taken or you use a reverse proxy.
PORT=80
